// File: tb_{{ top_name }}_regs.v
// Breif: Testbench for module {{ top_name }}.
`timescale 1 ns / 1 ps
//
`default_nettype none

module tb_{{ top_name }}_regs;

    reg         s_axi_aclk;
    reg         s_axi_aresetn;
    //
    reg  [{{ '{:2d}'.format(addr_width-1) }}:0] s_axi_awaddr;
    reg  [ 2:0] s_axi_awprot;
    reg         s_axi_awvalid;
    wire        s_axi_awready;
    //
    reg  [{{ '{:2d}'.format(data_width-1) }}:0] s_axi_wdata;
    reg  [{{ '{:2.0f}'.format(data_width/8-1) }}:0] s_axi_wstrb;
    reg         s_axi_wvalid;
    wire        s_axi_wready;
    //
    wire [ 1:0] s_axi_bresp;
    wire        s_axi_bvalid;
    reg         s_axi_bready;
    //
    reg  [{{ '{:2d}'.format(addr_width-1) }}:0] s_axi_araddr;
    reg  [ 2:0] s_axi_arprot;
    reg         s_axi_arvalid;
    wire        s_axi_arready;
    //
    wire [{{ '{:2d}'.format(data_width-1) }}:0] s_axi_rdata;
    wire [ 1:0] s_axi_rresp;
    wire        s_axi_rvalid;
    reg         s_axi_rready;

    {%- for field in fields %}
        {%- if field.is_hw_readable or field.is_hw_writable %}
    // {{ field.hierarchy }}
            {%- if field.is_hw_writable %}
    reg  [{{ '{:6d}'.format(field.width-1) }}:0] {{ field.name }}_in;
            {%- endif %}
            {%- if field.is_hw_readable %}
    wire [{{ '{:6d}'.format(field.width-1) }}:0] {{ field.name }}_out;
            {%- endif %}
        {%- endif %}
    {%- endfor %}
    {%- for mem in mems %}
    // {{ mem.hierarchy }}
    wire [{{ '{:2d}'.format(mem.addr_width-1) }}:0] {{ mem.name }}_addr;
    wire        {{ mem.name }}_en;
    wire        {{ mem.name }}_we;
    wire [{{ '{:2d}'.format(mem.width-1) }}:0] {{ mem.name }}_din;
    reg  [{{ '{:2d}'.format(mem.width-1) }}:0] {{ mem.name }}_dout;
    reg         {{ mem.name }}_valid;
    {%- endfor %}

    integer errors;

    task axi_reset();
        begin
            s_axi_awaddr  <= 0;
            s_axi_awprot  <= 0;
            s_axi_awvalid <= 0;
            //
            s_axi_wdata   <= 0;
            s_axi_wstrb   <= 0;
            s_axi_wvalid  <= 0;
            //
            s_axi_bready  <= 0;
            //
            s_axi_araddr  <= 0;
            s_axi_arprot  <= 0;
            s_axi_arvalid <= 0;
            //
            s_axi_rready  <= 0;
        end
    endtask

    task regs_reset();
        begin
            {%- for field in fields %}
                {%- if field.is_hw_writable %}
            // {{ field.hierarchy }}
            {{ field.name }}_in <= 0;
                {%- endif %}
            {%- endfor %}
            {%- for mem in mems %}

            // {{ mem.hierarchy }}
            {{ mem.name }}_dout <= 0;
            {{ mem.name }}_valid <= 0;
            {%- endfor %}
        end
    endtask

    task reset();
        begin
            s_axi_aresetn <= 0;
            repeat(16) @(posedge s_axi_aclk);
            s_axi_aresetn <= 1;
            repeat(16) @(posedge s_axi_aclk);
        end
    endtask

    task axi_write(input  reg [{{ '{:2d}'.format(addr_width-1) }}:0] addr,
                   input  reg [{{ '{:2d}'.format(data_width-1) }}:0] data,
                   output reg [ 1:0] resp);
        begin
            fork
                begin
                  s_axi_awaddr  <= addr;
                  s_axi_awprot  <= 0;
                  s_axi_awvalid <= 1;
                  @(posedge s_axi_aclk);
                  while (s_axi_awready == 0) begin
                      @(posedge s_axi_aclk);
                  end
                  s_axi_awvalid <= 0;
                end

                begin
                    s_axi_wdata  <= data;
                    s_axi_wstrb  <= 4'b1111;
                    s_axi_wvalid <= 1;
                    @(posedge s_axi_aclk);
                    while (s_axi_wready == 0) begin
                        @(posedge s_axi_aclk);
                    end
                    s_axi_wvalid <= 0;
                end

                begin
                    s_axi_bready <= 1;
                    @(posedge s_axi_aclk);
                    while (s_axi_bvalid == 0) begin
                        @(posedge s_axi_aclk);
                    end
                    resp = s_axi_bresp;
                    s_axi_bready <= 0;
                end
            join
            $display("Write: addr = %x, data = %x, resp = %x\n", addr, data, resp);
        end
    endtask

    task axi_read(input  reg [{{ '{:2d}'.format(addr_width-1) }}:0] addr,
                  output reg [{{ '{:2d}'.format(data_width-1) }}:0] data,
                  output reg [ 1:0] resp);
        begin
            fork
                begin
                    s_axi_araddr  <= addr;
                    s_axi_arprot  <= 0;
                    s_axi_arvalid <= 1;
                    @(posedge s_axi_aclk);
                    while (s_axi_arready == 0) begin
                        @(posedge s_axi_aclk);
                    end
                    s_axi_arvalid <= 0;
                end

                begin
                    s_axi_rready <= 1;
                    @(posedge s_axi_aclk);
                    while (s_axi_rvalid == 0) begin
                        @(posedge s_axi_aclk);
                    end
                    data = s_axi_rdata;
                    resp = s_axi_rresp;
                    s_axi_rready <= 0;
                end
            join
            $display("Read: addr = %x, data = %x, resp = %x\n", addr, data, resp);
        end
    endtask

    task check_resp(input reg [{{ '{:2d}'.format(addr_width-1) }}:0] addr,
                    input reg [ 1:0] resp);
        begin
            if (resp !== 2'b00) begin
                errors = errors + 1;
                $display("FAIL: addr = %x unexpected resp = %b", addr, resp);
            end
        end
    endtask

    task check_data(input reg [{{ '{:2d}'.format(addr_width-1) }}:0] addr,
                    input reg [{{ '{:2d}'.format(data_width-1) }}:0] got,
                    input reg [{{ '{:2d}'.format(data_width-1) }}:0] exp);
        begin
            if (got !== exp) begin
                errors = errors + 1;
                $display("FAIL: addr = %x data got = %x exp = %x", addr, got, exp);
            end
        end
    endtask


    // DUT

    {{ top_name }}_regs DUT (
        .s_axi_aclk                              (s_axi_aclk),
        .s_axi_aresetn                           (s_axi_aresetn),
        //
        .s_axi_awaddr                            (s_axi_awaddr),
        .s_axi_awprot                            (s_axi_awprot),
        .s_axi_awvalid                           (s_axi_awvalid),
        .s_axi_awready                           (s_axi_awready),
        //
        .s_axi_wdata                             (s_axi_wdata),
        .s_axi_wstrb                             (s_axi_wstrb),
        .s_axi_wvalid                            (s_axi_wvalid),
        .s_axi_wready                            (s_axi_wready),
        //
        .s_axi_bresp                             (s_axi_bresp),
        .s_axi_bvalid                            (s_axi_bvalid),
        .s_axi_bready                            (s_axi_bready),
        //
        .s_axi_araddr                            (s_axi_araddr),
        .s_axi_arprot                            (s_axi_arprot),
        .s_axi_arvalid                           (s_axi_arvalid),
        .s_axi_arready                           (s_axi_arready),
        //
        .s_axi_rdata                             (s_axi_rdata),
        .s_axi_rresp                             (s_axi_rresp),
        .s_axi_rvalid                            (s_axi_rvalid),
        .s_axi_rready                            (s_axi_rready)
        {%- for field in fields %}
            {%- if field.is_hw_readable or field.is_hw_writable -%}
        ,
        // {{ field.hierarchy }}
                {%- if field.is_hw_writable -%}
        ,
        .{{ '{: <40}'.format(field.name + '_in') }}({{ field.name }}_in)
                {%- endif %}
                {%- if field.is_hw_readable -%}
        ,
        .{{ '{: <40}'.format(field.name + '_out') }}({{ field.name }}_out)
                {%- endif %}
            {%- endif %}
        {%- endfor %}
        {%- for mem in mems -%}
        ,
        // {{ mem.hierarchy }}
        .{{ '{: <40}'.format(mem.name + '_addr') }}({{ mem.name }}_addr),
        .{{ '{: <40}'.format(mem.name + '_en') }}({{ mem.name }}_en),
        .{{ '{: <40}'.format(mem.name + '_we') }}({{ mem.name }}_we),
        .{{ '{: <40}'.format(mem.name + '_din') }}({{ mem.name }}_din),
        .{{ '{: <40}'.format(mem.name + '_dout') }}({{ mem.name }}_dout),
        .{{ '{: <40}'.format(mem.name + '_valid') }}({{ mem.name }}_valid)
        {%- endfor %}
    );


    // Memory Model

    {%- for mem in mems %}

    // {{ mem.hierarchy }}

    reg [31:0] {{ mem.name}}_mem [0:{{ mem.mementries }}];
    reg [{{ '{:2d}'.format(mem.width-1) }}:0] {{ mem.name}}_exp [0:{{ mem.mementries }}];

    always @(posedge s_axi_aclk) begin
        if ({{ mem.name}}_en == 1'b1) begin
            {{ mem.name }}_dout <= {{ mem.name}}_mem[{{ mem.name}}_addr];
        end
    end

    always @(posedge s_axi_aclk) begin
        if ({{ mem.name}}_en == 1'b1 && {{ mem.name}}_we == 1'b1) begin
            {{ mem.name}}_mem[{{ mem.name}}_addr] <= {{ mem.name }}_din;
        end
    end

    always @(posedge s_axi_aclk) begin
        {{ mem.name}}_valid <= {{ mem.name}}_en;
    end

    {%- endfor %}


    // Stimulation
    //------------

    initial begin
        s_axi_aclk = 0;
        forever begin
            #5 s_axi_aclk = ~s_axi_aclk;
        end
    end

    initial begin : p_stimu
        reg [{{ '{:2d}'.format(addr_width-1) }}:0] addr;
        reg [{{ '{:2d}'.format(data_width-1) }}:0] wdata;
        reg [{{ '{:2d}'.format(data_width-1) }}:0] rdata;
        reg [ 1:0] resp;
        integer i;

        errors = 0;

        // Wait reset done
        axi_reset();
        regs_reset();
        reset();

        // Write / read test
        {%- for field in fields %}

        // {{ field.hierarchy }}
        addr = 'h{{ '{:x}'.format(field.address) }};
            {%- if field.is_hw_writable %}
        {{ field.name }}_in <= $urandom();
        @(posedge s_axi_aclk);
            {%- endif %}
            {%- if field.is_sw_writable %}
        wdata = $urandom();
        axi_write(addr, wdata, resp);
        check_resp(addr, resp);
            {%- endif %}
            {%- if field.is_sw_readable %}
        axi_read(addr, rdata, resp);
        check_resp(addr, resp);
                {%- if field.is_hw_writable %}
        check_data(addr, rdata & {{ data_width }}'h{{ '{:x}'.format(field.mask) }},
                   ({{ data_width }}'({{ field.name }}_in) << {{ field.lsb }}) & {{ data_width }}'h{{ '{:x}'.format(field.mask) }});
                {%- elif field.is_sw_writable %}
        check_data(addr, rdata & {{ data_width }}'h{{ '{:x}'.format(field.mask) }},
                   wdata & {{ data_width }}'h{{ '{:x}'.format(field.mask) }});
                {%- else %}
        check_data(addr, rdata & {{ data_width }}'h{{ '{:x}'.format(field.mask) }},
                   ({{ data_width }}'h{{ '{:x}'.format(field.reset) }} << {{ field.lsb }}) & {{ data_width }}'h{{ '{:x}'.format(field.mask) }});
                {%- endif %}
            {%- endif %}
        {%- endfor %}
        {%- for mem in mems %}

        // {{ mem.hierarchy }}
            {%- if mem.is_sw_writable %}
        for (i = 0; i < {{ mem.mementries }}; i = i + 1) begin
            addr = ('h{{ '{:x}'.format(mem.address) }} + i * 4);
            wdata = $urandom();
            {{ mem.name }}_exp[i] = wdata[{{ mem.width-1 }}:0];
            axi_write(addr, wdata, resp);
            check_resp(addr, resp);
        end
            {%- endif %}
            {%- if mem.is_sw_readable %}
        for (i = 0; i < {{ mem.mementries }}; i = i + 1) begin
            addr = ('h{{ '{:x}'.format(mem.address) }} + i * 4);
            axi_read(addr, rdata, resp);
            check_resp(addr, resp);
                {%- if mem.is_sw_writable %}
            check_data(addr, rdata[{{ mem.width-1 }}:0], {{ mem.name }}_exp[i]);
                {%- endif %}
        end
            {%- endif %}
        {%- endfor %}
        #1000;
        if (errors == 0) begin
            $display("TEST PASSED");
            $finish;
        end else begin
            $display("TEST FAILED: %0d error(s)", errors);
            $fatal(1);
        end
    end

endmodule

`default_nettype wire
